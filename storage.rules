rules_version = '2';

// Craft rules based on the specific structures
// Anyone can view profile image, but only the owner can modify them
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile Images
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Team Logos - Only allow write if the filename starts with the user's UID
    match /teams_logos/{logoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && logoId.startsWith(request.auth.uid + '_');
    }

    // Chat Attachments - Only allow read/write if the user is a participant of the chat in Firestore
    match /chats/{chatId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        chatId.matches('.*' + request.auth.uid + '.*') ||
        firestore.get(/databases/ai-studio-2de7abc7-05e1-4ba5-9e5a-b99f52e0d3b8/documents/contactRequests/$(chatId)).data.fromUid == request.auth.uid ||
        firestore.get(/databases/ai-studio-2de7abc7-05e1-4ba5-9e5a-b99f52e0d3b8/documents/contactRequests/$(chatId)).data.toUid == request.auth.uid
      );
    }
    
    // Default fallback (block anything else)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
